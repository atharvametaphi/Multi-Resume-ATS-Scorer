APP_ENV=development
APP_NAME=AI Resume Analyzer
API_V1_PREFIX=/api/v1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173
SQLITE_DB_PATH=backend/app.db
MAX_UPLOAD_SIZE_MB=5
